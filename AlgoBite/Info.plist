<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- AdMob アプリ ID。INFOPLIST_KEY_ では Xcode に認識されず生成 Info.plist に
	     入らないため、ここで明示的に指定する。GENERATE_INFOPLIST_FILE=YES のまま
	     INFOPLIST_FILE にこのファイルを指定すると、自動生成キーとマージされる。 -->
	<key>GADApplicationIdentifier</key>
	<string>ca-app-pub-5057819549270171~3453559229</string>
	<!-- 暗号化は HTTPS/TLS など OS 標準のみ＝輸出規制の非対象。
	     これによりビルドアップロード時の輸出コンプライアンス申告ダイアログをスキップする。 -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
</dict>
</plist>
